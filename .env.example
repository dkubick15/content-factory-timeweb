# APP_SECRET необязателен. Если не задан, сервер автоматически сгенерирует случайный 32-байтный ключ
# и сохранит его в data/secret.key для повторного использования.
APP_SECRET=
PUBLIC_BASE_URL=https://your-domain.example
MAX_UPLOAD_MB=200
AI_TIMEOUT_MS=180000
AI_MAX_TOKENS=8000

# Интеграция с ИИ-агентами Timeweb Cloud (meweb.cloud)
# Замените на ваш JWT токен и ID созданного агента
TIMEWEB_API_KEY=
TIMEWEB_AGENT_ID=
