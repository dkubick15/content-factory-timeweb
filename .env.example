# APP_SECRET необязателен. Если не задан, сервер автоматически сгенерирует случайный 32-байтный ключ
# и сохранит его в data/secret.key для повторного использования.
APP_SECRET=
PUBLIC_BASE_URL=https://your-domain.example
MAX_UPLOAD_MB=200
AI_TIMEOUT_MS=180000
AI_MAX_TOKENS=8000
DEFAULT_AI_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Для OpenRouter вместо Groq:
# DEFAULT_AI_MODEL=deepseek/deepseek-v4-flash:free
OPENROUTER_API_KEY=
# Укажи прокси-сервер или кастомный базовый URL для OpenRouter:
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Интеграция с ИИ-агентами Timeweb Cloud (meweb.cloud)
# Замените на ваш JWT токен и ID созданного агента
TIMEWEB_API_KEY=
TIMEWEB_AGENT_ID=
